# ── Client (safe to expose; bundled into the browser by Vite) ──────────────
# Supabase project URL and ANON key. The anon key is designed to be public and
# is protected by Row Level Security — it is not a secret.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Server only (NEVER exposed to the browser) ─────────────────────────────
# Consumed by the /api/analyze serverless proxy (see api/analyze.ts).
# Set this in Vercel → Settings → Environment Variables. Do NOT add a VITE_
# prefix, or it will be inlined into the client bundle.
# If unset, the app falls back to a local, deterministic summary.
CLAUDE_API_KEY=sk-ant-your-anthropic-key
